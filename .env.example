# Environment Variables — PondFlow
# Salin file ini menjadi .env.local dan isi nilainya

# ============================================================
# SUPABASE
# ============================================================
# Dapatkan dari: https://supabase.com/dashboard → project → Settings → API
# Catatan: "Anon Key" = "Publishable Key" — nama berbeda di dashboard baru Supabase, fungsi sama
# Isi ANON_KEY dengan nilai "Publishable Key" yang ada di dashboard Supabase Anda
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...  (isi dengan Publishable Key dari dashboard)

# Service role key — hanya untuk server-side, JANGAN tambahkan NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# GOOGLE GEMINI AI
# ============================================================
# Dapatkan GRATIS dari: https://aistudio.google.com/app/apikey
# JANGAN tambahkan NEXT_PUBLIC_ — hanya digunakan di server (API route)
GEMINI_API_KEY=AIzaSy...

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
